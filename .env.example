DEBUG=False
SECRET_KEY=5OAbjbdJLnUT21uZIj7I3wukhOd1pL5PL7jyAhv

# Cloudflare Tunnel — get token from Zero Trust → Networks → Tunnels → Create tunnel
CLOUDFLARE_TUNNEL_TOKEN=
ALLOWED_HOSTS=localhost,127.0.0.1,snodeos.flyhomemnlab.com
CSRF_TRUSTED_ORIGINS=https://snodeos.flyhomemnlab.com

# Database (used by Docker Compose)
POSTGRES_DB=snodeos
POSTGRES_USER=snodeos
POSTGRES_PASSWORD=choose_a_strong_password
DATABASE_URL=postgres://snodeos:choose_a_strong_password@db:5432/snodeos

# Email — set these for real email delivery in production
# Options: Gmail / SendGrid / Mailgun — see /manage/email/ for setup guide
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=you@gmail.com
EMAIL_HOST_PASSWORD=your_gmail_app_password
DEFAULT_FROM_EMAIL=noreply@snodeos.flyhomemnlab.com

# Where officer alerts go (new applications, contact messages)
NOTIFICATION_EMAIL=officers@yourdomain.com

# Full public URL used in email links
SITE_URL=https://snodeos.flyhomemnlab.com
