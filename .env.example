DEBUG=False
SECRET_KEY=your-secret-key-here-change-this

# Cloudflare Tunnel — get token from Zero Trust → Networks → Tunnels → Create tunnel
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here
ALLOWED_HOSTS=localhost,127.0.0.1,snodeos.flyhomemnlab.com
CSRF_TRUSTED_ORIGINS=https://snodeos.flyhomemnlab.com

# Database (used by Docker Compose)
POSTGRES_DB=snodeos
POSTGRES_USER=snodeos
POSTGRES_PASSWORD=choose_a_strong_password
DATABASE_URL=postgres://snodeos:choose_a_strong_password@db:5432/snodeos

# Email — set these for real email delivery in production
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.yourprovider.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=you@yourdomain.com
EMAIL_HOST_PASSWORD=your_smtp_password
DEFAULT_FROM_EMAIL=noreply@snodeos.flyhomemnlab.com
